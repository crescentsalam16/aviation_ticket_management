<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_ticket_sales_document">
        <t t-call="web.external_layout">
            <t t-set="wizard" t-value="docs"/>
            <div class="page">
                <style>
                    .report-header { background: #1a2e4a; color: white; padding: 12px 16px; margin-bottom: 16px; }
                    .report-header h2 { color: white; margin: 0; }
                    .report-header .sub { font-size: 0.85em; opacity: 0.8; }
                    table.summary { width: 100%; border-collapse: collapse; margin-bottom: 16px; }
                    table.summary th { background: #1a2e4a; color: white; padding: 6px 10px; font-size: 0.85em; }
                    table.summary td { padding: 5px 10px; font-size: 0.82em; border-bottom: 1px solid #eee; }
                    table.summary tr:nth-child(even) td { background: #f7f9fc; }
                    .badge { display: inline-block; padding: 2px 8px; border-radius: 10px; font-size: 0.75em; font-weight: bold; }
                    .badge-paystack { background: #00C3F0; color: white; }
                    .badge-airvend { background: #FF6B35; color: white; }
                    .badge-gds { background: #6c757d; color: white; }
                    .badge-agent { background: #20c997; color: white; }
                    .badge-direct { background: #0d6efd; color: white; }
                    .kpi-row { display: flex; gap: 12px; margin-bottom: 16px; }
                    .kpi-card { flex: 1; border: 1px solid #dee2e6; border-radius: 6px; padding: 10px 14px; }
                    .kpi-card .label { font-size: 0.75em; color: #6c757d; text-transform: uppercase; }
                    .kpi-card .value { font-size: 1.4em; font-weight: bold; color: #1a2e4a; }
                    .totals-row td { font-weight: bold; background: #e9ecef; }
                </style>

                <div class="report-header">
                    <h2>Ticket Sales Report</h2>
                    <span class="sub">
                        Period: <t t-esc="wizard.date_from"/> to <t t-esc="wizard.date_to"/> |
                        Channel: <t t-esc="dict(wizard._fields['pos_channel'].selection).get(wizard.pos_channel, 'All')"/> |
                        Generated: <t t-esc="context_timestamp(datetime.datetime.now()).strftime('%d %b %Y %H:%M')"/>
                    </span>
                </div>

                <t t-set="tickets" t-value="env['aviation.ticket'].search(wizard._build_domain())"/>
                <t t-set="total_face" t-value="sum(tickets.mapped('face_value'))"/>
                <t t-set="total_net" t-value="sum(tickets.mapped('net_sales'))"/>
                <t t-set="total_comm" t-value="sum(tickets.mapped('comm'))"/>
                <t t-set="total_tax" t-value="sum(tickets.mapped('total_taxes'))"/>

                <!-- KPI Summary -->
                <div class="kpi-row">
                    <div class="kpi-card">
                        <div class="label">Total Tickets</div>
                        <div class="value"><t t-esc="len(tickets)"/></div>
                    </div>
                    <div class="kpi-card">
                        <div class="label">Gross Revenue</div>
                        <div class="value"><t t-esc="'{:,.2f}'.format(total_face)"/></div>
                    </div>
                    <div class="kpi-card">
                        <div class="label">Net Sales</div>
                        <div class="value"><t t-esc="'{:,.2f}'.format(total_net)"/></div>
                    </div>
                    <div class="kpi-card">
                        <div class="label">Total Commission</div>
                        <div class="value"><t t-esc="'{:,.2f}'.format(total_comm)"/></div>
                    </div>
                    <div class="kpi-card">
                        <div class="label">Total Taxes</div>
                        <div class="value"><t t-esc="'{:,.2f}'.format(total_tax)"/></div>
                    </div>
                </div>

                <!-- POS Breakdown -->
                <h4>Sales by Point of Sale</h4>
                <table class="summary">
                    <thead>
                        <tr>
                            <th>Channel</th>
                            <th>Count</th>
                            <th>Gross Revenue</th>
                            <th>Commission</th>
                            <th>Net Sales</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-set="channels" t-value="tickets.mapped('pos_channel')"/>
                        <t t-foreach="set(channels)" t-as="ch">
                            <t t-set="ch_tickets" t-value="tickets.filtered(lambda t: t.pos_channel == ch)"/>
                            <tr>
                                <td>
                                    <span t-attf-class="badge badge-#{ch or 'other'}">
                                        <t t-esc="dict(tickets._fields['pos_channel'].selection).get(ch, ch or 'N/A')"/>
                                    </span>
                                </td>
                                <td><t t-esc="len(ch_tickets)"/></td>
                                <td><t t-esc="'{:,.2f}'.format(sum(ch_tickets.mapped('face_value')))"/></td>
                                <td><t t-esc="'{:,.2f}'.format(sum(ch_tickets.mapped('comm')))"/></td>
                                <td><t t-esc="'{:,.2f}'.format(sum(ch_tickets.mapped('net_sales')))"/></td>
                            </tr>
                        </t>
                        <tr class="totals-row">
                            <td>TOTAL</td>
                            <td><t t-esc="len(tickets)"/></td>
                            <td><t t-esc="'{:,.2f}'.format(total_face)"/></td>
                            <td><t t-esc="'{:,.2f}'.format(total_comm)"/></td>
                            <td><t t-esc="'{:,.2f}'.format(total_net)"/></td>
                        </tr>
                    </tbody>
                </table>

                <!-- Ticket Detail -->
                <h4>Ticket Detail</h4>
                <table class="summary">
                    <thead>
                        <tr>
                            <th>Ticket No</th>
                            <th>Passenger</th>
                            <th>Route</th>
                            <th>Channel</th>
                            <th>Date</th>
                            <th>Face Value</th>
                            <th>Comm</th>
                            <th>Net Sales</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-foreach="tickets" t-as="t">
                            <tr>
                                <td><t t-esc="t.ticket_no"/></td>
                                <td><t t-esc="t.passenger_name or ''"/></td>
                                <td><t t-esc="t.route or ''"/></td>
                                <td>
                                    <span t-attf-class="badge badge-#{t.pos_channel or 'other'}">
                                        <t t-esc="dict(t._fields['pos_channel'].selection).get(t.pos_channel, '')"/>
                                    </span>
                                </td>
                                <td><t t-esc="t.transaction_date or ''"/></td>
                                <td style="text-align:right"><t t-esc="'{:,.2f}'.format(t.face_value)"/></td>
                                <td style="text-align:right"><t t-esc="'{:,.2f}'.format(t.comm)"/></td>
                                <td style="text-align:right"><t t-esc="'{:,.2f}'.format(t.net_sales)"/></td>
                                <td><t t-esc="dict(t._fields['status'].selection).get(t.status, '')"/></td>
                            </tr>
                        </t>
                    </tbody>
                </table>
            </div>
        </t>
    </template>

    <record id="action_report_ticket_sales" model="ir.actions.report">
        <field name="name">Ticket Sales Report</field>
        <field name="model">aviation.report.wizard</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">aviation_ticket_management.report_ticket_sales_document</field>
        <field name="report_file">aviation_ticket_management.report_ticket_sales_document</field>
        <field name="binding_model_id" ref="model_aviation_report_wizard"/>
        <field name="paperformat_id" ref="base.paperformat_us"/>
    </record>
</odoo>
