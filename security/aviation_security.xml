<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="module_aviation_ticket_management" model="ir.module.category">
            <field name="name">Aviation</field>
            <field name="description">Aviation Ticket Management</field>
            <field name="sequence">50</field>
        </record>

        <record id="group_aviation_readonly" model="res.groups">
            <field name="name">Read Only</field>
            <field name="category_id" ref="module_aviation_ticket_management"/>
        </record>

        <record id="group_aviation_user" model="res.groups">
            <field name="name">User</field>
            <field name="category_id" ref="module_aviation_ticket_management"/>
            <field name="implied_ids" eval="[(4, ref('group_aviation_readonly'))]"/>
        </record>

        <record id="group_aviation_manager" model="res.groups">
            <field name="name">Manager</field>
            <field name="category_id" ref="module_aviation_ticket_management"/>
            <field name="implied_ids" eval="[(4, ref('group_aviation_user'))]"/>
            <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
        </record>
    </data>
</odoo>
